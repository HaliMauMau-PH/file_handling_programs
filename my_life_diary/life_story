import tkinter as tk
from tkinter import messagebox


class LifeStory:
    def __init__(self, root, filename):
        self.filename = filename
        self.root = root
        self.root.title("My Life Story")
        self.root.geometry("400x300")
        self.root.config(bg="lightblue")

        self.title_label = tk.Label(root, text="Write your story", font=("Helvetica", 16, "bold"), bg="lightblue")
        self.title_label.pack(pady=10)

    def write_story(self):
        print(f"Writing my life story to {self.filename}...\n")
        
        try:
            with open(self.filename, "w") as file:
            
                while True:
                    user_line = input("Enter a line: ")
                    file.write(user_line + "\n")
                    more_lines = input("Do you want to add more lines? (y/n): ").strip().lower()
                    if not more_lines.startswith ("y"):
                        break
                    
            print(f"\nSuccess! Your life story has been saved to {self.filename}.")
            
        except Exception as e:
            print(f"An error occurred while writing to the file: {e}")
            
            
    def playback(self):
        print("\nPlaying back your life story...\n")
        
        try:
            with open(self.filename, "r")as file:
                story_content = file.read()
                if story_content.strip():
                    print(story_content, end="")
                else:
                    print("Your life story is empty.")
        
        except FileNotFoundError:
            print(f"Error: The file {self.filename} was not found.")
                
                
if __name__ == "__main__":
    writer = LifeStory("mylife.txt")
    writer.write_story()
    writer.playback()