import tkinter as tk
from tkinter import messagebox


class LifeStory:
    def __init__(self, root, filename):
        self.filename = filename
        self.root = root
        self.root.title("My Life Story")
        self.root.geometry("400x400")
        self.root.config(bg="lightblue")

        self.title_label = tk.Label(root, text="Write your story", font=("Helvetica", 16, "bold"), bg="lightblue")
        self.title_label.pack(pady=10)

        self.text_area = tk.Text(root, 
                                wrap=tk.WORD,
                                width=55,
                                height=10, 
                                font=("Arial", 12), 
                                )
        self.text_area.pack (padx=20, pady=10,)
        
        self.button_frame = tk.Frame(root,
                                    bg = "lightblue"
                                    )
        self.button_frame.pack(pady=15)
        
        self.save_button = tk.Button(self.button_frame,
                                    text="Save Story",
                                    command=self.save_story,
                                    bg="lightgreen",
                                    fg="black",
                                    font=("Arial", 12, "bold"),
                                    width=15
        )
        self.save_button.grid(row=0, column=0, padx=10)
        
        self.playback_button = tk.Button(self.button_frame,
                                        text="Read Playback",
                                        command=self.playback,
                                        bg="orange",
                                        fg="black",
                                        font=("Arial", 12, "bold"),
                                        width=12)
        
        self.playback_button.grid(row=0, column=1, padx=10)
        
    def save_story(self):
        content = self.text_area.get("1.0", tk.END).strip()
        
        if not content:
            messagebox.showwarning("Empty Story", "Please write something before saving.")
            return
        try:
            with open(self.filename, "a") as file:
                file.write(content + "\n")
            messagebox.showinfo("Success", f"Your story has been saved to {self.filename}.")
            self.text_area.delete("1.0", tk.END)
        except Exception as e:
            messagebox.showerror("Error", f"An error occurred while saving the story: {e}")
                                             
    def playback(self):
        print("\nPlaying back your life story...\n")
        
        try:
            with open(self.filename, "r")as file:
                story_content = file.read()
                if story_content.strip():
                    messagebox.showinfo("Story Playback", story_content)
                else:
                    messagebox.showwarning("Empty", "Your life story is empty.")
        
        except FileNotFoundError:
            messagebox.showerror("Error", f"The file {self.filename} was not found. Save a story first!")
                
                
if __name__ == "__main__":
    root = tk.Tk()
    
    writer = LifeStory(root, "mylife.txt")
    
    root.mainloop()
