class LifeStory:
    def __init__(self, filename):
        self.fiename = filename
        
        
    def write_story(self):
        print("Writing my life story...")
        
        try:
            with open(self.filename, "w") as file:
            
                while True:
                    user_line = input("Enter a line: ")
                    file.write(user_line + "\n")
                    more_lines = input("Do you want to add more lines? (yes/no): ").strip().lower()
                    if more_lines != "yes":
                        break
                    
            print(f"\nSuccess! Your life story has been saved to {self.filename}.")
            
        except Exception as e:
            print(f"An error occurred while writing to the file: {e}")
            
            
    def playback(self):
        print("\nPlaying back your life story...\n")
        
        try:
            with open(self.filename, "r")as file:
                story_content = file.read()
                if story_content.strip():
                    print(story_content, end="")
                else:
                    print("Your life story is empty.")
        
        except FileNotFoundError:
            print(f"Error: The file {self.filename} was not found.")
                
                
if __name__ == "__main__":
    writer = LifeStory("mylife.txt")
    writer.write_story()