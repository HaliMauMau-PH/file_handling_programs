import tkinter as tk
from tkinter import messagebox
import random

class IntegerTransformer:
    def __init__(self, root, input_file, double_file, triple_file):
        self.root = root
        self.input_file = input_file
        self.double_file = double_file
        self.triple_file = triple_file
        
        self.even_count = 0
        self.odd_count = 0
        
        # GUI Setup
        self.root.title("Integer Transformer")
        self.root.geometry("400x500")
        self.root.config(bg="lightyellow")
        #title
        self.title_lbl = tk.Label(self.root, text="Integer Transformer", font=("Helvetica", 16, "bold"), bg="lightyellow", fg="black")
        self.title_lbl.pack(pady=20)
        #screen
        self.console_screen = tk.Text(self.root, width=55, height=12, bg="black", fg="#00ff00", font=("Consolas", 10))
        self.console_screen.pack(pady=10)
        self.console_screen.insert(tk.END, "System Ready. Waiting for data...\n")
        #buttons
        self.btn_frm = tk.Frame(self.root, bg="lightyellow")
        self.btn_frm.pack(pady=20)
        #button generate
        self.btn_generate = tk.Button(self.btn_frame, text="1. Generate Data", command=self.generate_input_file, bg="#f1c40f", font=("Arial", 10, "bold"), width=15)
        self.btn_generate.grid(row=0, column=0, padx=10)
        #button transform
        self.btn_transform = tk.Button(self.btn_frame, text="2. Transform Data", command=self.transform_numbers, bg="#e67e22", font=("Arial", 10, "bold"), width=15)
        self.btn_transform.grid(row=0, column=1, padx=10)
        
        def log_to_screen(self, message):
            self.console_screen.insert(tk.END, message + "\n")
            self.console_screen.see(tk.END)
        
        def generate_input_file(self):
            self.console_screen.delete("1.0", tk.END)
            self.log_to_screen(f"Generating random integers in {self.input_file}...")
            


            with open(self.input_file,'w') as f:
                for _ in range (20):
                    random_num = random.randint(1, 100)
                    f.write(f"{random_num}\n")
                
            self.log_to_screen("[*] Generation Complete! Ready for transformation.\n")
            messagebox.showinfo("Generated", "20 random numbers have been created!")
                
    def transform_numbers(self):
        self.even_count = 0 # Reset counters
        self.odd_count = 0
        
        
        try:
            with open(self.input_file, 'r') as infile, \
                 open(self.double_file, 'w') as double_out, \
                 open(self.triple_file, 'w') as triple_out:

                for line in infile:
                    if not line.strip():
                        continue
                    
                try:
                    number = int(line.strip())
                    
                    if number % 2 == 0:
                        square = number ** 2
                        double_out.write(f"{number} -> {square}\n")
                    else:
                        cube = number ** 3
                        triple_out.write(f"{number} -> {cube}\n")
                        
                except ValueError:
                    self.log_to_screen(f"[!] Skipping invalid data: {line.strip()}")
            
            self.display_summary()
            print(f"Transformation complete. Check {self.double_file} and {self.triple_file} for results.")
                  
        except FileNotFoundError:
            messagebox.showerror("File Error", "Integers file not found! Click 'Generate Data' first.")
            
    def display_summary(self):
        """Prints a final report to the GUI console."""
        self.log_to_screen("-" * 40)
        self.log_to_screen("TRANSFORMATION SUMMARY")
        self.log_to_screen("-" * 40)
        self.log_to_screen(f"Even Numbers Squared: {self.even_count} (Saved to {self.double_file})")
        self.log_to_screen(f"Odd Numbers Cubed:    {self.odd_count} (Saved to {self.triple_file})")
        self.log_to_screen("-" * 40)
        self.log_to_screen("[*] Process 100% Complete.")
    
if __name__ == "__main__":
    root = tk.Tk()
    
    app = IntegerTransformer(root, "integers.txt", "double.txt", "triple.txt")
    
    root.mainloop()