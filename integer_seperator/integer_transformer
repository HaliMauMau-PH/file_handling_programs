import tkinter as tk
from tkinter import messagebox
import random

class IntegerTransformer:
    def __init__(self, input_file, double_file, triple_file):
        self.input_file = input_file
        self.double_file = double_file
        self.triple_file = triple_file
        
        self.even_count = 0
        self.odd_count = 0
        

        self.root.title = "Integer Transformer"
        self.root.geometry("400x500")
        self.root.config(bg="lightyellow")
        
        self.title_lbl = tk.Label(self.root, text="Integer Transformer", font=("Helvetica", 16, "bold"), bg="lightyellow", fg="black")
        self.title_lbl.pack(pady=20)
        
        
        
        
        
        
        
    def generate_input_file(self):
        with open(self.input_file,'w') as f:
            for _ in range (20):
                random_num = random.randint(1, 100)
                f.write(f"{random_num}\n")
                
                
    def transform_numbers(self):
        try:
            infile = open(self.input_file, 'r')
            
            double_out = open(self.double_file, 'w')
            triple_out = open(self.triple_file, 'w')

            for line in infile:
                if not line.strip():
                    continue
                    
                try:
                    number = int(line.strip())
                    
                    if number % 2 == 0:
                        square = number ** 2
                        double_out.write(f"{number} -> {square}\n")
                    else:
                        cube = number ** 3
                        triple_out.write(f"{number} -> {cube}\n")
                        
                except ValueError:
                    print(f"Skipping invalid integer: {line.strip()}")
                    
            infile.close()
            double_out.close()
            triple_out.close()
            
            print(f"Transformation complete. Check {self.double_file} and {self.triple_file} for results.")
                  
        except FileNotFoundError:
            print(f"Error: The file {self.input_file} was not found.")
    
if __name__ == "__main__":
    
    
    transformer = IntegerTransformer("integers.txt", "double.txt", "triple.txt")
    
    transformer.generate_input_file()
    
    transformer.transform_numbers()