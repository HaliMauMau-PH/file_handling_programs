import random

class GWAAnalyzer:
    def __init__(self, filename):
        self.filename = filename

    def generate_class(self):
        first_names = ["Juan", "Maria", "Pedro", "Ana", "Carlos", "Isabella", "Miguel", "Sofia", "Luis", "Carmen"]
        last_names = ["Dela Cruz", "Garcia", "Reyes", "Ramos", "Mendoza", "Santos", "Flores", "Gonzales", "Bautista", "Aquino"]
        print(f"Making Class in {self.filename}")
        with open(self.filename, 'w') as file:
            for _ in range (20):
                first = random.choice(first_names)
                last = random.choice(last_names)
                name = f"{first} {last}"
                gwa = round(random.uniform(1.0, 5.0), 2)
                file.write(f"{name}, {gwa}\n")

    def find_highest_gwa(self):
        highest_gwa = float('inf')
        top_student = ""
    
        try:
            student_file = open(self.filename, 'r')
        
            for line in student_file:
                if not line.strip():
                    continue
                
                data = line.strip().split(',')
                
                if len(data) == 2:
                    name = data[0].strip()
                    try:
                        gwa = float(data[1].strip())
                
                        if gwa < highest_gwa:
                            highest_gwa = gwa
                            top_student = name
                    except ValueError:
                        print(f"skipping Invalid GWA for {name}")
            student_file.close()
        
            if top_student:
                print(f"Top Student: {top_student}")
                print(f"The GWA: {highest_gwa}")

        except FileNotFoundError:
            print(f"Error: the file {self.filename} was not found") 
            
    def Podium(self):
        if not self.students:
            print("No students found.")
            return
        
        self.students.sort(key=lambda x: x[1])

        print("-" *40)
        print("Podium")
        print("-"*40)
        podium = ["🥇 1st Place:", "🥈 2nd Place:", "🥉 3rd Place:"]
        
        
if __name__ == "__main__":
    analyzer = GWAAnalyzer("student.txt")

    analyzer.generate_class()
    
    analyzer.find_highest_gwa()
              