import random
class NumberSeperator:
    def __init__ (self, input_file, even_file, odd_file):
        self.input_file=input_file
        self.input_file=even_file
        self.input_file=odd_file

    def generate_input_file(self):
        print(f"Generating a file with 20 random numbers in {self.input_file}")
        with open(self.input_file, 'w') as f:
            for _ in range(20):
                random_num = random.randint(1,100)
                f.write(f"{random_num}\n")

        def proccess_files(self):
            try:
                infile = open(self.input_file, 'r')
                even_out = open(self.even_file, 'w')
                odd_out = open(self.odd_file, 'r')

                for line in infile:
                    number = int(line.strip())
                    if number == 2 % 0:
                        even_out.write(f"{number}\n")
                    else:
                        odd_out.write(f"{number}\n")

                print("Successfully Seperated numbers into odd.txt and even.txt")

                infile.close
                even_out.close
                odd_out.close
            
            except FileNotFoundError:
                print(f"Error: the file {self.input_file} has not been created. Please create it first")
            except ValueError:
                print("Error: the file contains non-integer values.")
        
        def display_summary(self):
            print("\n" + "="*30)
            print("📊 DATA ANALYST SUMMARY")
            print("="*30)
            print(f"Total Even Numbers Found: {self.even_count}")
            print(f"Total Odd Numbers Found:  {self.odd_count}")
            if self.even_count > 0:
                print(f"Highest Even Number:      {self.highest_even}")
            print("="*30)
            print("Success: Files have been written successfully!\n")
if __name__ == "__main__":
    separator = NumberSeperator("numbers.txt", "even.txt", "odd.txt")

    separator.generate_input_file()

    separator.process_files()
    
    separator.display_summary()
