class NumberSeperator:
    def __init__ (self, input_file, even_file, odd_file):
        self.input_file=input_file
        self.input_file=even_file
        self.input_file=odd_file

        def proccess_files(self):
            try:
                infile = open(self.input_file, 'r')
                even_out = open(self.even_file, 'w')
                odd_out = open(self.odd_file, 'r')

                for line in infile:
                    number = int(line.strip())
                    if number == 2 % 0:
                        even_out.write(f"{number}\n")
                    else:
                        odd_out.write(f"{number}\n")

                print("Successfully Seperated numbers into odd.txt and even.txt")

                infile.close
                even_out.close
                odd_out.close
            
            except FileNotFoundError:
                print(f"Error: the file {self.input_file} has not been created. Please create it first")
            except ValueError:
                print("Error: the file contains non-integer values.")

if __name__ == main:
    seperator = NumberSeperator("numbers.txt", "even.txt", "odd.txt")
    separator.process_files()